  "description": "${mod_description}",
  "authors": [
    "${mod_authors}"
  ],
  "license": "${mod_license}",
  "environment": "*",

  "entrypoints": {
    "main": [
      "com.darkbladenemo.cobblemoncharms.CobblemonCharmsFabric"
    ],
